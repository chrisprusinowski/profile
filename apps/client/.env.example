# Copy this file to .env.local for local development with the API backend.
# When this is set, the app reads employees from the live API (which watches
# data/employees.csv for changes). Without it, the app uses data bundled at
# build time from data/employees.csv — suitable for GitHub Pages.

VITE_API_URL=http://localhost:4000

# Optional: override the base URL for GitHub Pages deployments at a custom path.
# VITE_BASE_URL=/profile/
