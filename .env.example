# Shared
NODE_ENV=development

# API
API_PORT=4000
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/app_db

# Client (Vite)
# Local full-stack mode: point client directly at API.
VITE_API_URL=http://localhost:4000
# For root local hosting, keep '/'. For GitHub Pages repo hosting, use '/profile/'.
VITE_BASE_URL=/

# Legacy web service (not required for MVP local flow)
WEB_PORT=3000
API_BASE_URL=http://localhost:4000

# Postgres
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
